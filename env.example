# Sao chép thành .env.local

# MongoDB — bắt buộc; toàn bộ dữ liệu app lưu tại đây
MONGODB_URI=mongodb://127.0.0.1:27017/hpay_web

# Telegram — tạo bot qua @BotFather; chỉ cần token là bot chạy cùng Next (next dev / next start)
# TELEGRAM_BOT_TOKEN=

# Username bot không có @ (tuỳ chọn — nếu bỏ trống server gọi getMe khi tạo link từ dashboard)
# TELEGRAM_BOT_USERNAME=my_hpay_bot

# URL web hiển thị trong bot (tuỳ chọn)
# APP_BASE_URL=http://localhost:3001

# IBFT sandbox / merchant (form Admin → Chi hộ tự điền khi có)
# HPAY_IBFT_TEST_ACC_NUMBER=
# HPAY_IBFT_TEST_BANK=KLB
# HPAY_IBFT_TEST_ACC_NAME=
# HPAY_ACCOUNT_CODE=
# HPAY_MERCHANT_NAME=
# HPAY_CONTACT_EMAIL=
